          "properties": {
            "tckType": "ZGF0YXByZXAtZnVuY3Rpb25zI0RhdGFwcmVwI1NxbEV4cHJlc3Npb24==",
            "configuration": {
              "sqlExpressions": [
                {
                  "newColumnName": "SUPPLIER_JOIN_KEY",
                  "datatype": {
                    "type": "STRING",
                    "length": 256,
                    "precision": 18,
                    "scale": 2
                  },
                  "nullable": true,
                  "expression": {
                    "expressionStatement": "CASE\n\n  WHEN (${ENV} = \u0027A\u0027 or ${ENV}  = \u0027C\u0027) and ${Vendor_Number} \u003C\u003E \u0027VCOCINTERCO\u0027\n    THEN concat(${ENV},right(concat(\u0027000000\u0027,substring(${Vendor_Number},1,charindex(${ENV},${Vendor_Number})-1)),6))\n  ELSE ${Vendor_Number}\n\nEND",
                    "alias": [
                      {
                        "name": "ENV",
                        "value": "ENV"
                      },
                      {
                        "name": "Vendor_Number",
                        "value": "Vendor_Number"
                      }
                    ]
                  }
                }
              ],
              "$state": "CONFIGURED"
            }
